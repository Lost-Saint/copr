From: COPR packaging
Subject: [PATCH] setup.py: read __version__ without importing the package

The lutris/__init__.py now calls gi.require_version() at import time,
which makes the package un-importable during %pyproject_buildrequires
(setuptools' run_setup evaluates setup.py before runtime deps are
guaranteed). Read the version string from the file directly.

--- a/setup.py
+++ b/setup.py
@@ -1,10 +1,15 @@
 #!/usr/bin/env python3
 import os
+import re
 import sys

 from setuptools import setup

-from lutris import __version__ as VERSION
+with open(os.path.join(os.path.dirname(__file__), "lutris", "__init__.py")) as _f:
+    _match = re.search(r'^__version__\s*=\s*"([^"]+)"', _f.read(), re.MULTILINE)
+if not _match:
+    sys.exit("Could not find __version__ in lutris/__init__.py")
+VERSION = _match.group(1)

 if sys.version_info < (3, 10):
     sys.exit("Python >= 3.10 is required to run Lutris")
